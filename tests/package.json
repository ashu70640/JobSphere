{
  "name": "jobsphere-tests",
  "version": "1.0.0",
  "description": "Complete test suite for JobSphere — unit, integration, E2E, load, security, frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "test:unit": "vitest run --config vitest.config.js --reporter=verbose unit/",
    "test:integration": "vitest run --config vitest.config.js --reporter=verbose integration/",
    "test:security": "vitest run --config vitest.config.js --reporter=verbose security/",
    "test:backend": "vitest run --config vitest.config.js --reporter=verbose",
    "test:frontend": "vitest run --config vitest.frontend.config.js --reporter=verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:load:login": "k6 run load/login.load.test.js",
    "test:load:jobs": "k6 run load/jobs.load.test.js",
    "test:load:ai": "k6 run load/ai.load.test.js",
    "test:coverage": "vitest run --config vitest.config.js --coverage",
    "test:coverage:frontend": "vitest run --config vitest.frontend.config.js --coverage",
    "test:all": "npm run test:backend && npm run test:frontend",
    "test:watch": "vitest --config vitest.config.js",
    "playwright:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^1.2.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsdom": "^23.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^9.1.4",
    "mongoose": "^8.0.0",
    "multer": "^2.0.0",
    "pdf-parse": "^1.1.1",
    "supertest": "^6.3.3",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  }
}
