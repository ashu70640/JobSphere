# Dependencies
node_modules/
**/node_modules/

# Environment variables — NEVER commit secrets
services/auth/.env
services/jobs/.env
services/admin/.env

# Frontend env
client/.env              # local dev — empty VITE_* vars, uses Vite proxy
client/.env.production   # default production build (auto-generated)
client/.env.local        # personal local overrides
# .env.render and .env.aws ARE committed — they contain no secrets, only public URLs

# Build output
client/dist/
client/build/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Docker volumes (not needed in repo)
mongo-data/
mongo-config/

# Claude AI files
CLAUDE.md
.claude/
*.claude
