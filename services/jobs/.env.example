# ── Core ─────────────────────────────────────────────────────────────────────
PORT=5002
MONGO_URI=mongodb://localhost:27017/jobsdb
JWT_SECRET=your_jwt_secret_here          # must match auth service

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key

# ── Google Calendar (jobs service uses these to build OAuth2 client) ──────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Inter-service auth ────────────────────────────────────────────────────────
# Must match INTERNAL_SERVICE_SECRET in auth service .env
INTERNAL_SERVICE_SECRET=your_shared_service_secret_here

# Auth service URL — used to fetch Google tokens for calendar sync
# Docker:    http://auth-service:5001
# Local dev: http://localhost:5001
AUTH_SERVICE_URL=http://localhost:5001
