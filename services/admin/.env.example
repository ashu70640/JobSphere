# JobSphere Admin — new file, safe to delete without affecting core app
PORT=5003

# Read-only connections to existing databases
MONGO_URI_AUTH=mongodb://localhost:27017/authdb
MONGO_URI_JOBS=mongodb://localhost:27017/jobsdb

# Admin JWT — must be different from the main app JWT_SECRET
ADMIN_JWT_SECRET=your_admin_jwt_secret_change_this

# Seed superadmin credentials (used on first startup if admin collection is empty)
ADMIN_EMAIL=admin@jobsphere.com
ADMIN_PASSWORD=changeme123
