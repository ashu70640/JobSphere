# ── Core ─────────────────────────────────────────────────────────────────────
PORT=5001
MONGO_URI=mongodb://localhost:27017/authdb
JWT_SECRET=your_jwt_secret_here          # min 32 random chars
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com
# Enable "Google Calendar API"
# Create OAuth 2.0 credentials (Web application type)
# Add authorised redirect URI: http://localhost/api/v1/auth/calendar/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/calendar/callback

# Frontend URL — where to redirect after OAuth callback
CLIENT_URL=http://localhost:5173

# ── Token encryption ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes for AES-256)
TOKEN_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# ── Inter-service auth ────────────────────────────────────────────────────────
# Shared secret between auth-service and jobs-service
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SERVICE_SECRET=your_shared_service_secret_here
